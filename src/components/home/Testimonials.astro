---
// Archivo: src/components/home/Testimonials.astro
import { testimonialsData } from "../../data/testimonials";
---

<section class="flex bg-[url(/ruido.png)] bg-no-repeat bg-cover justify-center pb-32 pt-16 border-t border-gray-800 relative z-10" id="testimonios">
  <div class="w-11/12 mx-auto">
    
    <div class="flex justify-between py-4 mb-16 border-b border-gray-800">
      <p class="text-quaternary uppercase tracking-widest text-sm">reputación *</p>
      <p class="parrafe text-tertiary">OUTPUT</p>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-8">
      <h2 
        class="title text-[4rem] md:text-[7rem] leading-none text-quaternary uppercase w-full md:w-1/2"
        style="text-shadow: 1px 1px 40px rgba(255, 255, 255, 0.2);"
      >
        LO QUE <br> CONSTRUIMOS
      </h2>
      <p class="parrafe text-xl text-tertiary w-full md:w-1/3 pt-4 border-t border-gray-600 md:border-t-0 md:border-l md:pl-8">
        No pedimos que confíes ciegamente. Estos son los resultados de combinar sistemas escalables y arquitectura visual.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-gray-800">
      {testimonialsData.map((testimonial, index) => (
        <div class={`p-8 md:p-12 group hover:bg-white hover:text-black transition-all duration-300 border-gray-800 
          ${index % 2 === 0 ? 'border-b md:border-r' : 'border-b'} 
          ${index >= testimonialsData.length - 2 ? 'border-b-0' : ''}
        `}>
          <div class="flex justify-between items-start mb-8 text-tertiary group-hover:text-black">
            <span class="parrafe text-sm uppercase tracking-widest">TESTIMONIO // {testimonial.id}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"></path></svg>
          </div>
          
          <p class="parrafe text-xl md:text-2xl leading-relaxed text-quaternary group-hover:text-black mb-12">
            "{testimonial.comment}"
          </p>
          
          <div class="mt-auto">
            <p class="title text-2xl uppercase">{testimonial.client}</p>
            <p class="parrafe text-sm uppercase tracking-widest text-tertiary group-hover:text-gray-700">{testimonial.role}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>