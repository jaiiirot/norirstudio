---
---
<section class="flex bg-[url(/ruido.png)] bg-no-repeat bg-cover justify-center pb-24">
  <div class="border-t border-gray-600 w-11/12 mx-auto mt-24 text-tertiary">
    <div class="flex justify-between py-4 mb-12">
      <p class="text-quaternary">proyectos *</p>
      <p><span class="text-quaternary">04</span> // 05</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      <a href="#" class="group col-span-1 md:col-span-8 relative overflow-hidden block h-[400px]">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover grayscale-100 group-hover:scale-105 transition-transform duration-700" alt="Proyecto Arquitectura">
        <div class="absolute bottom-0 left-0 p-6 bg-black/80 w-full md:w-auto">
          <h4 class="title text-quaternary text-3xl">EDIFICIO CONCEPTUAL</h4>
          <p class="parrafe text-tertiary text-sm uppercase mt-1">Render / Postproducción</p>
        </div>
      </a>

      <a href="#" class="group col-span-1 md:col-span-4 relative overflow-hidden block h-[400px]">
        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800&auto=format&fit=crop" class="w-full h-full object-cover grayscale-100 group-hover:scale-105 transition-transform duration-700" alt="Proyecto Web">
        <div class="absolute bottom-0 left-0 p-6 bg-black/80 w-full md:w-auto">
          <h4 class="title text-quaternary text-3xl">PLATAFORMA ESTUDIANTIL</h4>
          <p class="parrafe text-tertiary text-sm uppercase mt-1">Full-Stack / UI</p>
        </div>
      </a>
    </div>
  </div>
</section>