---
// Archivo: src/components/home/Projects.astro
// 1. Importamos la data que creamos antes
import { projectsData } from "../../data/projects";

// 2. Tomamos solo los primeros 4 proyectos para mostrarlos como galería en el inicio
const featuredProjects = projectsData.slice(0, 4);
---

<section class="flex bg-[url(/ruido.png)] bg-no-repeat bg-cover justify-center pb-24" id="proyectos">
  <div class="border-t border-gray-600 w-11/12 mx-auto mt-24 text-tertiary">
    
    <div class="flex justify-between py-4 mb-16">
      <p class="text-quaternary uppercase tracking-widest text-sm">proyectos destacados *</p>
      <p><span class="text-quaternary">04</span> // 05</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-24">
      {featuredProjects.map((project) => (
        <div class="group relative h-[450px] overflow-hidden border border-gray-800 cursor-crosshair">
          
          <img 
            src={project.image} 
            alt={project.title} 
            class="w-full h-full object-cover grayscale-100 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700 opacity-60 group-hover:opacity-100"
          />
          
          <div class="absolute inset-0 flex flex-col justify-between p-6 bg-gradient-to-t from-black/90 via-black/30 to-transparent">
            
            <div class="self-end border border-quaternary/50 px-2 py-1 text-quaternary text-xs uppercase tracking-widest backdrop-blur-sm">
              {project.category}
            </div>
            
            <div class="transform translate-y-8 group-hover:translate-y-0 transition-transform duration-500 flex flex-col gap-2">
              <h3 class="title text-3xl md:text-4xl text-quaternary leading-none uppercase">{project.title}</h3>
              <p class="parrafe text-xs text-tertiary uppercase tracking-widest mb-4">
                {project.service} // {project.year}
              </p>
              
              <a 
                href={`/proyectos/${project.slug}`} 
                class="w-max parrafe text-xs uppercase tracking-widest bg-white text-black px-4 py-2 hover:bg-tertiary hover:text-white transition-all opacity-0 group-hover:opacity-100"
              >
                Ver Preview →
              </a>
            </div>

          </div>
        </div>
      ))}
    </div>

    <div class="flex justify-center border-t border-gray-800 pt-16">
      <a 
        href="/proyectos" 
        class="title text-[2.5rem] md:text-[5rem] lg:text-[7rem] leading-none text-quaternary hover:text-gray-400 transition-colors text-center w-full group"
        style="text-shadow: 1px 1px 40px rgba(255, 255, 255, 0.2);"
      >
        <span class="inline-block group-hover:-translate-y-2 transition-transform duration-300">VER TODOS</span> 
        <br class="md:hidden" />
        <span class="inline-block group-hover:-translate-y-2 transition-transform duration-300 delay-75 border-b-2 border-transparent group-hover:border-quaternary pb-2">LOS PROYECTOS</span>
      </a>
    </div>

  </div>
</section>