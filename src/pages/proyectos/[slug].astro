---
// Archivo: src/pages/proyectos/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { projectsData } from "../../data/projects";

// Astro exige esta función para saber qué páginas generar en build time
export function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { slug: project.slug },
    props: { project }, // Pasamos el proyecto completo como prop
  }));
}

const { project } = Astro.props;
---

<Layout>
  <main class="bg-[url(/ruido.png)] bg-no-repeat bg-cover bg-fixed min-h-screen pt-32 pb-24 text-quaternary">
    
    <article class="w-11/12 mx-auto">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-gray-600 pb-8 mb-12 gap-8">
        <a href="/proyectos" class="parrafe text-tertiary hover:text-white uppercase tracking-widest text-sm border-b border-transparent hover:border-white transition-all">
          ← Volver al Archivo
        </a>
        
        <div class="flex gap-12 text-left">
          <div>
            <p class="text-tertiary text-xs uppercase tracking-widest mb-1">Categoría</p>
            <p class="parrafe">{project.category}</p>
          </div>
          <div>
            <p class="text-tertiary text-xs uppercase tracking-widest mb-1">Servicio</p>
            <p class="parrafe">{project.service}</p>
          </div>
          <div>
            <p class="text-tertiary text-xs uppercase tracking-widest mb-1">Año</p>
            <p class="parrafe">{project.year}</p>
          </div>
        </div>
      </div>

      <h1 
        class="title text-[3.5rem] md:text-[6rem] lg:text-[10rem] leading-none mb-12"
        style="text-shadow: 1px 1px 40px rgba(255, 255, 255, 0.3);"
      >
        {project.title}
      </h1>

      <div class="w-full h-[50vh] md:h-[70vh] mb-16 overflow-hidden border border-gray-800">
        <img 
          src={project.image} 
          alt={project.title} 
          class="w-full h-full object-cover grayscale-100"
        />
      </div>

      <div class="flex flex-col lg:flex-row gap-16 justify-between">
        <div class="w-full lg:w-2/3">
          <p class="text-quaternary uppercase tracking-widest text-sm mb-6 border-b border-gray-800 pb-2 w-max">OVERVIEW *</p>
          <p class="parrafe text-xl md:text-2xl leading-relaxed text-gray-300">
            {project.description}
          </p>
        </div>
        
        <div class="w-full lg:w-1/3 border-l border-gray-800 pl-8">
          <p class="text-quaternary uppercase tracking-widest text-sm mb-6 border-b border-gray-800 pb-2 w-max">TECNOLOGÍAS *</p>
          <ul class="flex flex-col gap-4">
            {project.techStack.map((tech) => (
              <li class="parrafe text-lg text-tertiary hover:text-white transition-colors flex items-center gap-4 before:content-['//'] before:text-gray-600">
                {tech}
              </li>
            ))}
          </ul>
        </div>
      </div>

    </article>
  </main>
</Layout>