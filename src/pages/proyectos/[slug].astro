---
// Archivo: src/pages/proyectos/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { projectsData } from "../../data/projects";

export function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const pageTitle = `${project.title} | NORIR STUDIO`;
---

<Layout title={pageTitle} description={project.description}>
  <main class="bg-[url(/ruido.png)] bg-no-repeat bg-cover bg-fixed min-h-screen text-quaternary">
    
    <header class="relative w-full h-screen flex flex-col justify-end pb-12 pt-32 overflow-hidden border-b border-gray-800">
      <img 
        src={project.image} 
        alt={project.title} 
        class="absolute inset-0 w-full h-full object-cover grayscale-100 opacity-40 mix-blend-luminosity pointer-events-none"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent pointer-events-none"></div>
      
      <div class="relative z-10 w-11/12 mx-auto flex flex-col">
        <a href="/proyectos" class="parrafe text-tertiary hover:text-white uppercase tracking-widest text-sm border-b border-gray-800 hover:border-white transition-all w-max mb-12">
          ← Volver al Archivo
        </a>
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
          <h1 
            class="title text-[4rem] md:text-[8rem] lg:text-[12rem] leading-none tracking-tighter uppercase"
            style="text-shadow: 1px 1px 40px rgba(255, 255, 255, 0.2);"
          >
            {project.title}
          </h1>
          
          <div class="flex flex-row md:flex-col gap-8 md:gap-4 text-left md:text-right border-l md:border-l-0 md:border-r border-gray-600 pl-4 md:pl-0 md:pr-4 pb-2">
            <div>
              <p class="text-tertiary text-xs uppercase tracking-widest mb-1">Índice</p>
              <p class="parrafe text-xl">{project.id}</p>
            </div>
            <div>
              <p class="text-tertiary text-xs uppercase tracking-widest mb-1">Año</p>
              <p class="parrafe text-xl">{project.year}</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <article class="w-11/12 mx-auto py-24">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-32 border-b border-gray-800 pb-24">
        
        <div class="lg:col-span-4 flex flex-col gap-12">
          <div>
            <p class="text-quaternary uppercase tracking-widest text-sm mb-4 border-b border-gray-800 pb-2">CATEGORÍA *</p>
            <p class="parrafe text-xl text-tertiary">{project.category}</p>
          </div>
          <div>
            <p class="text-quaternary uppercase tracking-widest text-sm mb-4 border-b border-gray-800 pb-2">SERVICIO *</p>
            <p class="parrafe text-xl text-tertiary">{project.service}</p>
          </div>
          <div>
            <p class="text-quaternary uppercase tracking-widest text-sm mb-4 border-b border-gray-800 pb-2">TECNOLOGÍAS *</p>
            <ul class="flex flex-wrap gap-3">
              {project.techStack.map((tech) => (
                <li class="parrafe text-sm uppercase tracking-widest border border-gray-600 px-3 py-1 text-tertiary">
                  {tech}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="lg:col-span-8">
          <p class="text-quaternary uppercase tracking-widest text-sm mb-6 border-b border-gray-800 pb-2 w-max">OVERVIEW *</p>
          <p class="parrafe text-2xl md:text-4xl leading-snug text-gray-300">
            {project.description}
          </p>
        </div>
      </div>

      <div class="w-full">
        <p class="text-quaternary uppercase tracking-widest text-sm mb-12 border-b border-gray-800 pb-2 w-max">REGISTRO VISUAL *</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {project.gallery.map((img, index) => (
            <div 
              class={`group relative overflow-hidden border border-gray-800 cursor-crosshair 
                ${index === 0 ? 'md:col-span-2 h-[50vh] md:h-[80vh]' : 'h-[40vh] md:h-[60vh]'}
              `}
            >
              <img 
                src={img} 
                alt={`${project.title} - Galería ${index + 1}`} 
                class="w-full h-full object-cover grayscale-100 opacity-70 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
              />
              <div class="absolute bottom-4 left-4 bg-black text-white px-3 py-1 parrafe text-xs tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
                IMG // 0{index + 1}
              </div>
            </div>
          ))}
        </div>
      </div>

    </article>
    
    <div class="w-full border-t border-gray-800 py-32 flex justify-center items-center hover:bg-white hover:text-black transition-colors duration-500 group">
      <a href="/proyectos" class="title text-[3rem] md:text-[6rem] uppercase group-hover:translate-x-4 transition-transform text-center">
        VER MÁS PROYECTOS →
      </a>
    </div>

  </main>
</Layout>